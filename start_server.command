#!/bin/bash

# الانتقال إلى مسار مجلد المشروع تلقائياً
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$DIR"

echo "جارٍ تشغيل خادم مكتبة معهد الوادي..."
echo "يمكنك إغلاق هذه النافذة فقط لإيقاف الخادم أو استخدام ملف الإيقاف."
echo "الموقع متاح على: http://127.0.0.1:5000"

# تشغيل الخادم
python3 server.py
